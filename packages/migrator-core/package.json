{
  "name": "@wp2astro/migrator-core",
  "version": "0.1.0",
  "description": "Pure WordPress WXR -> Sanity migration primitives. Runtime-agnostic core used by the CLI and the SaaS worker.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch"
  },
  "dependencies": {
    "@sanity/block-tools": "^3.68.3",
    "@sanity/client": "^6.24.1",
    "@sanity/schema": "^3.68.3",
    "fast-xml-parser": "^4.5.1",
    "jsdom": "^25.0.1",
    "mime-types": "^2.1.35"
  },
  "devDependencies": {
    "@types/jsdom": "^21.1.7",
    "@types/mime-types": "^2.1.4",
    "@types/node": "^22.10.5",
    "typescript": "^5.7.2"
  }
}
