# Sanity (https://www.sanity.io/manage)
PUBLIC_SANITY_PROJECT_ID=your_project_id
PUBLIC_SANITY_DATASET=production
SANITY_API_READ_TOKEN=

# Site URL (used by sitemap, RSS, canonical tags)
PUBLIC_SITE_URL=https://example.com

# Resend (https://resend.com) - contact form email delivery
# Set these in Cloudflare Pages env vars for production. Local: copy to .dev.vars
RESEND_API_KEY=
CONTACT_TO_EMAIL=you@example.com
CONTACT_FROM_EMAIL=noreply@example.com
