{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "baseUrl": ".",
    "paths": {
      "~/*": ["src/*"]
    }
  },
  "include": ["src", "sanity.config.ts", "sanity.cli.ts", ".astro/types.d.ts"],
  "exclude": ["dist", ".astro", "node_modules"]
}
