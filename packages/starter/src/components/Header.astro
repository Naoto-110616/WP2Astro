---
import type { SiteSettings } from '~/sanity/types';

interface Props {
  settings: SiteSettings | null;
}

const { settings } = Astro.props;
const nav = settings?.navigation ?? [
  { label: 'ブログ', href: '/blog' },
  { label: 'お問い合わせ', href: '/contact' },
];
---

<header class="border-b border-slate-200/60 bg-white/80 backdrop-blur dark:border-slate-800 dark:bg-slate-950/80">
  <div class="mx-auto flex max-w-5xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8">
    <a href="/" class="text-lg font-bold tracking-tight">
      {settings?.title ?? 'WP2Astro'}
    </a>
    <nav class="flex items-center gap-6 text-sm">
      {
        nav.map((item) => (
          <a href={item.href} class="text-slate-600 transition hover:text-slate-900 dark:text-slate-400 dark:hover:text-slate-50">
            {item.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>
