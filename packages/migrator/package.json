{
  "name": "@wp2astro/migrator",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "WordPress WXR to Sanity migrator CLI. Thin Node wrapper over @wp2astro/migrator-core.",
  "bin": {
    "wp2astro": "./bin/wp2astro.mjs"
  },
  "scripts": {
    "start": "node --import tsx ./bin/wp2astro.mjs",
    "build": "tsc -p tsconfig.json",
    "dev": "node --import tsx --watch ./bin/wp2astro.mjs"
  },
  "dependencies": {
    "@sanity/client": "^6.24.1",
    "@wp2astro/migrator-core": "workspace:*",
    "chalk": "^5.4.1",
    "commander": "^12.1.0",
    "ora": "^8.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
